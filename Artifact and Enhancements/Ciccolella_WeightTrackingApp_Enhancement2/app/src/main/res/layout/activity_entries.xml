<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".EntriesActivity">

    <!-- Screen Title -->
    <TextView
        android:id="@+id/textViewEntriesTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Weight Log"
        android:textStyle="bold"
        android:textSize="22sp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Notifications / Settings Button -->
    <Button
        android:id="@+id/buttonNotifications"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notifications"
        android:textAllCaps="false"
        android:padding="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBaseline_toBaselineOf="@id/textViewEntriesTitle"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/buttonToggleSortOrder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Asc"
        android:textSize="14sp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBaseline_toBaselineOf="@id/textViewEntriesTitle"
        app:layout_constraintEnd_toStartOf="@id/buttonNotifications" />

    <!-- GraphView for Weight Tracking (Initially Hidden) -->
    <com.jjoe64.graphview.GraphView
        android:id="@+id/graph"
        android:layout_width="0dp"
        android:layout_height="300dp"
        app:layout_constraintTop_toBottomOf="@id/textViewEntriesTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:visibility="gone" /> <!-- Initially hidden -->

    <!-- Button to toggle Graph Visibility -->
    <Button
        android:id="@+id/buttonToggleGraph"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Show Graph"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/graph"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ScrollView for Entries List -->
    <ScrollView
        android:id="@+id/scrollEntries"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/buttonToggleGraph"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutAddEntry">

        <LinearLayout
            android:id="@+id/layoutEntriesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Row for Entries -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="#EEEEEE"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Date"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Weight"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Delete"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Entries rows will be added dynamically -->
        </LinearLayout>
    </ScrollView>

    <!-- Add Entry Section -->
    <LinearLayout
        android:id="@+id/layoutAddEntry"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#F5F5F5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textViewAddEntry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add New Entry"
            android:textStyle="bold"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/editTextEntryDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="Date (YYYY-MM-DD)"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/editTextEntryWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="Weight"
            android:inputType="numberDecimal"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonSaveEntry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Entry"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>